# 工单 worker 对接哪个 union-agent 代码目录：
# dev=../union-lab-union-agent-git-https（开发测试，默认 union_dev）
# runtime=../union-lab-union-agent-davinci-runtime（正式，默认 union_prod）
UNION_AGENT_TARGET=dev

# 如需临时指定任意目录，可用 UNION_AGENT_PATH 覆盖 UNION_AGENT_TARGET。
# UNION_AGENT_PATH=../union-lab-union-agent-git-https

# 默认会自动寻找同级目录下的 union-lab-union-knowledgebase-git-https
UNION_KNOWLEDGEBASE_PATH=../union-lab-union-knowledgebase-git-https

# worker 轮询间隔，默认 300 秒
DAVINCI_TASK_INTERVAL_SECONDS=300

# 每轮最多认领几张工单。建议先保持 1，避免生图供应商并发压力过大。
DAVINCI_TASK_BATCH_SIZE=1

# 默认使用 union-agent 的 .env.union-dev；如需切换可显式覆盖。
UNION_AGENT_ENV_FILE=.env.union-dev

# worker 会读取 union-agent env 中的 DATABASE_URL，并按 UNION_AGENT_TARGET 自动切库：
# dev => union_dev，runtime => union_prod。如需临时覆盖再显式设置。
# DAVINCI_TASK_DATABASE_NAME=union_dev

# 达芬奇专用连接池的 schema 搜索路径；不要改 union-agent 全局 get_pool()。
DAVINCI_DB_SEARCH_PATH=davinci,public,app

# false=默认国外 wolfai/Gemini 链路；worker 会在国外供应商失败时自动临时切国内网关兜底一次。
DAVINCI_CN_IMAGE_ENABLED=false
